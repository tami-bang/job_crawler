# FastAPI / DB
JOB_RADAR_DB_PATH=data/job_radar.db
JOB_RADAR_CORS_ORIGINS=https://tami-bang.github.io,http://localhost:3000,http://127.0.0.1:3000

# XLSX 이메일 첨부 발송용 SMTP
# Gmail을 쓰는 경우 일반 비밀번호가 아니라 앱 비밀번호를 사용하세요.
JOB_RADAR_SMTP_HOST=smtp.gmail.com
JOB_RADAR_SMTP_PORT=587
JOB_RADAR_SMTP_USER=
JOB_RADAR_SMTP_PASSWORD=
JOB_RADAR_SMTP_FROM=
JOB_RADAR_SMTP_TLS=true

# GitHub Pages 정적 프론트가 호출할 별도 FastAPI 배포 URL
# 예: https://your-job-radar-api.onrender.com
NEXT_PUBLIC_REPORT_API_URL=

# 네이버지도 기준 예상 이동시간
# Naver Cloud Platform Maps Geocoding + Direction API 키
NAVER_MAPS_CLIENT_ID=
NAVER_MAPS_CLIENT_SECRET=
# 위 두 값 대신 Naver Cloud Platform 헤더명과 맞춘 아래 이름도 지원합니다.
# X_NCP_APIGW_API_KEY_ID=
# X_NCP_APIGW_API_KEY=
