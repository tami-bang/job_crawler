{
  "saramin": {
    "name": "Saramin",
    "base_url": "https://www.saramin.co.kr/zf_user/search?searchType=search&searchword={keyword}&recruitPage={page}",
    "selectors": {
      "card": "div.item_recruit",
      "title": "h2.job_tit a",
      "company": "strong.corp_name",
      "location": "div.job_condition span.loc",
      "url": "h2.job_tit a"
    },
    "dynamic": true
  },
  "jobkorea": {
    "name": "JobKorea",
    "base_url": "https://www.jobkorea.co.kr/Search/?stext={keyword}&page={page}",
    "selectors": {
      "card": "div[data-sentry-component=\"CardJob\"]",
      "title": "a[data-sentry-component=\"Title\"]",
      "company": "",
      "location": "[data-sentry-component=\"GrayChip\"] span.truncate",
      "url": "a[data-sentry-component=\"Title\"]"
    },
    "dynamic": true
  }
}
